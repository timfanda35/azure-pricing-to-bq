# Google Cloud target
GCP_PROJECT=
BQ_DATASET=azure_pricing
BQ_LOCATION=US
GCS_STAGING_BUCKET=
GCS_STAGING_PREFIX=ingestion/

# Azure Retail Prices API
AZURE_API_VERSION=2023-01-01-preview
AZURE_CURRENCY=USD
AZURE_MAX_RETRIES=5
AZURE_REQUEST_TIMEOUT_S=30
# Optional OData $filter, e.g. serviceName eq 'Azure DNS'
AZURE_OPTIONAL_FILTER=

# Loader behavior
JSONL_BATCH_SIZE=10000
LOG_LEVEL=INFO
